{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "rewrites": [
    { "source": "/onboarding", "destination": "/index.html" },
    { "source": "/onboarding/:path*", "destination": "/index.html" }
  ],
  "headers": [
    {
      "source": "/assets/(.*)",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "public, max-age=31536000, immutable"
        }
      ]
    }
  ],
  "redirects": [
    {
      "source": "/",
      "has": [
        {
          "type": "host",
          "value": "nexo-landing-sigma\\.vercel\\.app"
        }
      ],
      "destination": "https://nexo.previncasalud.com.ar/",
      "permanent": true
    },
    {
      "source": "/:path*",
      "has": [
        {
          "type": "host",
          "value": "nexo-landing-sigma\\.vercel\\.app"
        }
      ],
      "destination": "https://nexo.previncasalud.com.ar/:path*",
      "permanent": true
    }
  ]
}
